<%- include('../partials/header') %>

<main>
    <!-- Hero Section -->
    <section class="hero">
        <div class="container hero-content">
            <h1>Selamat Datang di <br>PAUD ATTHOHIRIYYAH</h1>
            <p>Membentuk Generasi Cerdas, Ceria, dan Berakhlak Mulia Sejak Dini.</p>
            <div class="cta-buttons">
                <a href="/ppdb" class="btn btn-primary">Daftar Sekarang</a>
                <a href="#about" class="btn btn-secondary">Pelajari Lebih Lanjut</a>
            </div>
        </div>
    </section>

    <!-- About Section -->
    <section id="about" class="about">
        <div class="container">
            <h2 class="section-title">Kenapa Memilih Kami?</h2>
            <div class="info-grid">
                <div class="info-card">
                    <i class="fas fa-heart fa-3x" style="color: var(--primary); margin-bottom: 1rem;"></i>
                    <h3>Lingkungan Kasih Sayang</h3>
                    <p>Kami menyediakan lingkungan yang aman dan penuh kasih sayang untuk tumbuh kembang anak.</p>
                </div>
                <div class="info-card">
                    <i class="fas fa-palette fa-3x" style="color: var(--secondary); margin-bottom: 1rem;"></i>
                    <h3>Kurikulum Kreatif</h3>
                    <p>Metode pembelajaran yang menyenangkan melalui bermain dan eksplorasi kreatif.</p>
                </div>
                <div class="info-card">
                    <i class="fas fa-users fa-3x" style="color: var(--accent); margin-bottom: 1rem;"></i>
                    <h3>Tenaga Pengajar Ahli</h3>
                    <p>Didampingi oleh guru-guru berpengalaman yang mencintai dunia anak-anak.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Gallery Preview -->
    <section id="gallery" class="gallery" style="background: #f9f9f9;">
        <div class="container">
            <h2 class="section-title">Galeri Kegiatan</h2>
            <div class="gallery-grid">
                <% gallery.slice(0, 4).forEach(item => { %>
                    <div class="gallery-item">
                        <img src="/<%= item.file %>" alt="<%= item.title %>">
                    </div>
                <% }) %>
            </div>
            <div style="text-align: center; margin-top: 2rem;">
                <a href="/galeri" class="btn btn-secondary">Lihat Semua Foto</a>
            </div>
        </div>
    </section>

    <!-- Information Section -->
    <section id="info" class="information">
        <div class="container">
            <h2 class="section-title">Informasi Terbaru</h2>
            <div class="info-grid">
                <% information.slice(0, 3).forEach(item => { %>
                    <div class="info-card">
                        <span class="badge" style="background: var(--secondary); color: white; padding: 2px 10px; border-radius: 10px; font-size: 0.8rem;"><%= item.category %></span>
                        <h3 style="margin: 1rem 0;"><%= item.title %></h3>
                        <p><%= item.description.substring(0, 100) %>...</p>
                        <a href="/information-detail?id=<%= item.id %>" style="color: var(--primary); text-decoration: none; font-weight: bold; margin-top: 1rem; display: inline-block;">Baca Selengkapnya</a>
                    </div>
                <% }) %>
            </div>
        </div>
    </section>
</main>

<%- include('../partials/footer') %>
